/* =========================
   VENTAS
========================= */

app.post("/ventas", (req, res) => {
  const { producto_id, cantidad } = req.body;

  // 1. Obtener precio del producto
  const getProducto = "SELECT precio, stock FROM productos WHERE id = ?";

  db.query(getProducto, [producto_id], (err, result) => {
    if (err) return res.send(err);

    if (result.length === 0) {
      return res.status(404).send("Producto no encontrado");
    }

    const producto = result[0];

    if (producto.stock < cantidad) {
      return res.status(400).send("Stock insuficiente");
    }

    const total = producto.precio * cantidad;

    // 2. Guardar venta
    const insertVenta = `
      INSERT INTO ventas (producto_id, cantidad, total)
      VALUES (?, ?, ?)
    `;

    db.query(insertVenta, [producto_id, cantidad, total], (err2) => {
      if (err2) return res.send(err2);

      // 3. Descontar stock
      const updateStock = `
        UPDATE productos SET stock = stock - ?
        WHERE id = ?
      `;

      db.query(updateStock, [cantidad, producto_id], (err3) => {
        if (err3) return res.send(err3);

        res.json({
  mensaje: "Venta realizada correctamente",
  ok: true
});
      });
    });
  });
});

