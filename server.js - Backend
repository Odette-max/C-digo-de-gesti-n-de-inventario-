/* =========================
   REPORTES API
========================= */

app.get("/reportes", (req, res) => {
  const { tipo, inicio, fin } = req.query;

  let condicionFecha = "";

  // 📅 FILTRO PERSONALIZADO
  if (inicio && fin) {
    condicionFecha = `WHERE DATE(fecha) BETWEEN '${inicio}' AND '${fin}'`;
  } else {
    // 📊 FILTRO POR TIPO
    if (tipo === "diario") {
      condicionFecha = `WHERE DATE(fecha) = CURDATE()`;
    } 
    else if (tipo === "semanal") {
      condicionFecha = `WHERE YEARWEEK(fecha, 1) = YEARWEEK(CURDATE(), 1)`;
    } 
    else if (tipo === "mensual") {
      condicionFecha = `WHERE MONTH(fecha) = MONTH(CURDATE()) 
                        AND YEAR(fecha) = YEAR(CURDATE())`;
    }
  }

  // 🔥 CONSULTA PRINCIPAL
  const query = `
    SELECT 
      COUNT(*) AS totalVentas,
      IFNULL(SUM(total), 0) AS totalDinero,
      IFNULL(AVG(total), 0) AS promedioVenta
    FROM ventas
    ${condicionFecha}
  `;

  // 🏆 MEJOR DÍA
  const mejorDiaQuery = `
    SELECT DATE(fecha) as dia, SUM(total) as totalDia
    FROM ventas
    ${condicionFecha}
    GROUP BY dia
    ORDER BY totalDia DESC
    LIMIT 1
  `;

  // 🔄 EJECUTAR CONSULTAS
  db.query(query, (err, result) => {
    if (err) {
      console.log(err);
      return res.status(500).json({ error: "Error en reporte" });
    }

    db.query(mejorDiaQuery, (err2, result2) => {
      if (err2) {
        console.log(err2);
        return res.status(500).json({ error: "Error en mejor día" });
      }

      res.json({
        totalVentas: result[0].totalVentas,
        totalDinero: result[0].totalDinero,
        promedioVenta: result[0].promedioVenta,
        mejorDia: result2.length > 0 ? result2[0].dia : "Sin datos"
      });
    });
  });
});


