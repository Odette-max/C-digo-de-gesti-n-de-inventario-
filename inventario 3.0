      🏠 Inicio
    </button>
  </li>

  <li>
    <button
  className={`menu-btn ${vista === "inventario" ? "bg-blue-100 font-bold" : ""}`}
  onClick={() => setVista("inventario")}
>
  📦 Inventario
</button>
  </li>

  <li>
    <button
  className={`menu-btn ${vista === "ventas" ? "bg-blue-100 font-bold" : ""}`}
  onClick={() => setVista("ventas")}
>
  💰 Ventas
</button>
  </li>

  <li>
    <button
  className={`menu-btn ${vista === "reportes" ? "bg-blue-100 font-bold" : ""}`}
  onClick={() => setVista("reportes")}
>
  📊 Reportes
</button>
  </li>

  <li>
    <button
  className={`menu-btn ${vista === "usuarios" ? "bg-blue-100 font-bold" : ""}`}
  onClick={() => setVista("usuarios")}
>
  👤 Usuarios
</button>
  </li>

  <li>
<button
className={`menu-btn ${vista === "proveedores" ? "bg-blue-100 font-bold" : ""}`}
onClick={() => setVista("proveedores")}
>
🚚 Proveedores
</button>
</li>

<li>
<button
className={`menu-btn ${vista === "reabastecer" ? "bg-blue-100 font-bold" : ""}`}
onClick={() => setVista("reabastecer")}
>
📥 Reabastecer
</button>
</li>


</ul>

    </aside>

    {/* ===== CONTENIDO PRINCIPAL ===== */}
    <main className="flex-1 flex items-center justify-center p-6">

      <div className="bg-white/90 p-6 rounded-2xl shadow-xl w-full max-w-5xl min-h-[500px]">

        {vista === "home" && <Home setVista={setVista} usuario={usuario} setUsuario={setUsuario} />}
        {vista === "login" && <Login setVista={setVista} setUsuario={setUsuario} />}
        {vista === "inventario" && <Inventario setVista={setVista} />}
        {vista === "ventas" && <Ventas setVista={setVista} />}
        {vista === "reportes" && <Reportes setVista={setVista} />}
        {vista === "usuarios" && <Usuarios setVista={setVista} />}
        {vista === "proveedores" && <Proveedores setVista={setVista} />}
        {vista === "reabastecer" && <Reabastecer setVista={setVista} />}

      </div>
    </main>

  </div>
);

}
